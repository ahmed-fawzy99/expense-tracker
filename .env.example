# --------------------------------------------------------------------
# Auto-managed by `convex dev` on first run. You normally don't edit
# this file by hand — `convex dev` writes the real values into
# .env.local automatically.
#
# Copy this file to .env.local if your deployment is already set up
# elsewhere (e.g. CI/CD picking up CONVEX_DEPLOYMENT from a secret).
# --------------------------------------------------------------------

# Local Convex dev deployment id (set by `convex dev`). Format:
#   CONVEX_DEPLOYMENT=local:<slug>
#   CONVEX_DEPLOYMENT=dev:<name>     # for cloud dev
CONVEX_DEPLOYMENT=

# Public URL for the Convex backend (used by the React client).
VITE_CONVEX_URL=http://127.0.0.1:3210

# Public URL for the Convex auth /verify endpoints (used by the auth flow).
VITE_CONVEX_SITE_URL=http://127.0.0.1:3211
