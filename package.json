{
  "name": "expense-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "convex dev --start 'vite --open'",
    "predev": "convex init && node setup.mjs --once",
    "build": "tsc -b && vite build",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "predeploy": "pnpm lint && pnpm test",
    "deploy": "convex deploy --cmd 'pnpm build'",
    "test": "vitest run",
    "test:backend": "vitest run --project backend",
    "test:frontend": "vitest run --project frontend",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed": "convex run seed:run",
    "seed:fresh": "convex run seed:run '{\"fresh\":true}'",
    "preview": "vite preview"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/pt-mono": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.36.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.28",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "convex-test": "^0.0.50",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@tailwindcss/oxide"
    ]
  }
}